# Backend Environment Variables

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=rental_management

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_EXPIRY=7d

# Email Configuration (Gmail Example)
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@rentmanager.in

# Note: For Gmail, use "App Password" instead of your regular password
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Go to myaccount.google.com/apppasswords
# 3. Generate an app password for "Mail" and "Windows Computer"
# 4. Use that 16-character password as EMAIL_PASSWORD

# Server Configuration
PORT=5000
NODE_ENV=development

# Payment Configuration (Simulated)
PAYMENT_CURRENCY=INR
PAYMENT_UPI_ID=your-upi-id@bank

# Optional: Third-party services
STRIPE_KEY=your_stripe_key_here
PAYPAL_CLIENT_ID=your_paypal_client_id
